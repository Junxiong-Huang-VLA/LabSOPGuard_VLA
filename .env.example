# ============================================================
# LabEmbodied Environment Variables — copy to .env and fill in
# ============================================================
# IMPORTANT: Never commit .env to version control!
# This file (.env.example) is safe to commit as a template.

# PostgreSQL
POSTGRES_USER=labsop
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=labembodied

# MinIO Object Storage
MINIO_ROOT_USER=CHANGE_ME_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional: override service ports
# API_PORT=8080
# SGLANG_PORT=30000

# Qwen / DashScope APIs
# DASHSCOPE_API_KEY=CHANGE_ME
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ASR_PROVIDER=qwen
# ASR_MODEL=qwen3-asr-flash
# MATERIAL_EMBEDDING_PROVIDER=qwen
# MATERIAL_EMBEDDING_MODEL=text-embedding-v4
# MATERIAL_EMBEDDING_DIMENSION=1024

# Qwen frame writeback into material_stream.analysis.
# Disabled by default to control DashScope cost. It can also be enabled per
# /api/v1/experiments/{experiment_id}/process request.
# QWEN_FRAME_WRITEBACK_ENABLED=false
# QWEN_FRAME_WRITEBACK_FLASH_MODEL=qwen3.6-flash
# QWEN_FRAME_WRITEBACK_REVIEW_MODEL=qwen3.6-plus
# QWEN_FRAME_WRITEBACK_LIMIT=12
# QWEN_FRAME_WRITEBACK_FORCE_LIVE=false
# QWEN_FRAME_WRITEBACK_RETRIES=1
# QWEN_FRAME_WRITEBACK_TIMEOUT_SEC=90
# QWEN_FRAME_WRITEBACK_FAIL_PIPELINE=false

# YOLO26 detector runtime
# Model weights live OUTSIDE the repo in a central store (default D:\LabModels).
# Layout: <LAB_MODELS_DIR>\yolo\{first_person,third_person}\current\best.pt
#         plus \pose\ and \generic\ for shared weights. Override the root if needed.
# LAB_MODELS_DIR=D:\LabModels
# YOLO26_WEIGHTS_PATH=D:\LabModels\yolo\third_person\current\best.pt
# LABSOPGUARD_YOLO_MODEL=D:\LabModels\yolo\third_person\current\best.pt
# DETECTOR_DEVICE=auto
# YOLO26_CONFIDENCE_THRESHOLD=0.25
# YOLO26_IOU_THRESHOLD=0.45
# YOLO26_MAX_DETECTIONS=50

# Key-action long-video YOLO defaults
# KEY_ACTION_YOLO_DEVICE=0
# KEY_ACTION_YOLO_BATCH_SIZE=16
# KEY_ACTION_YOLO_STAGE_CACHE=1
# Leave the per-view model paths unset to auto-resolve <LAB_MODELS_DIR>\yolo\<view>\current\best.pt.
# KEY_ACTION_YOLO_FIRST_PERSON_MODEL=D:\LabModels\yolo\first_person\current\best.pt
# KEY_ACTION_YOLO_FIRST_PERSON_IMGSZ=640
# KEY_ACTION_YOLO_THIRD_PERSON_MODEL=D:\LabModels\yolo\third_person\current\best.pt
# Third-person keeps adaptive high-quality sizing by default.
# REALITYLOOP_MAX_VIDEO_UPLOAD_BYTES=34359738368
# Raw uploads are stored outside the repo; experiment folders keep only .video_ref.json pointers.
# LAB_VIDEO_STORE_ROOT=D:\LabVideo\raw_uploads
# LAB_MATERIAL_LIBRARY_ROOT=D:\LabMaterialLibrary
# KEY_ACTION_ENABLE_MICRO_REFINE_RESCAN=0
# KEY_ACTION_RENDER_EXPERIMENT_FOCUS_YOLO_DEFAULT=0
# KEY_ACTION_RENDER_SEGMENT_YOLO_DEFAULT=0
# KEY_ACTION_SEGMENT_OVERLAY_SOURCE=rows
# KEY_ACTION_FREEZE_REVIEWED_DATASET_DEFAULT=0
# KEY_ACTION_CREATE_REVIEWED_RELEASE_DEFAULT=0
# KEY_ACTION_WRITE_REVIEWED_EXPORT_DEFAULT=0
# KEY_ACTION_FOCUS_CLIP_PREVIEW_H264=1
# KEY_ACTION_FOCUS_CLIP_CRF=28
# KEY_ACTION_FOCUS_CLIP_MAX_WIDTH=1280
# KEY_ACTION_FOCUS_CLIP_VIDEO_BITRATE=3M
# KEY_ACTION_PREVIEW_CLIP_REENCODE=1
# KEY_ACTION_PREVIEW_CLIP_CRF=30
# KEY_ACTION_PREVIEW_CLIP_MAX_WIDTH=960
# KEY_ACTION_PREVIEW_CLIP_VIDEO_BITRATE=2M
# KEY_ACTION_PREVIEW_CLIP_INCLUDE_AUDIO=0
# KEY_ACTION_ENABLE_VLM_ASSIST=1
# KEY_ACTION_PROFESSIONAL_REPORT_ENABLED=0

# Docker deployment ports
# BACKEND_PORT=8000
# FRONTEND_PORT=80

# Redis (used by processing queue + cache)
# REDIS_URL=redis://redis:6379/0

# Notifications
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID

# Feishu OpenAPI outbound messages for step-material review.
# Keep real values in local .env only.
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=CHANGE_ME
# FEISHU_RECEIVE_ID=ou_xxx
# FEISHU_RECEIVE_ID_TYPE=open_id
# FEISHU_API_BASE=https://open.feishu.cn/open-apis
# FEISHU_TIMEOUT_SEC=20
# FEISHU_RETRIES=5
# LABSOPGUARD_PUBLIC_BASE_URL=http://127.0.0.1:8000
# FEISHU_EVENT_CALLBACK_URL=https://YOUR_PUBLIC_DOMAIN/api/v1/feishu/events
# FEISHU_VERIFICATION_TOKEN=CHANGE_ME_FROM_FEISHU_EVENT_SUBSCRIPTION
# FEISHU_ENCRYPT_KEY=CHANGE_ME_IF_EVENT_ENCRYPTION_IS_ENABLED
# FEISHU_DEFAULT_EXPERIMENT_ID=
# FEISHU_STEP_QUERY_LIMIT=5
# FEISHU_REPLY_WITH_EVIDENCE_IMAGE=1
