{
  "sender_id": "sender0",
  "camera": {
    "camera_id": "cam0",
    "enabled": true,
    "enable_depth_streams": false,
    "width": 1280,
    "height": 720,
    "fps": 30,
    "format_priority": ["RGB", "MJPG", "YUYV", "NV12"],
    "device_index": 0
  },
  "codec": {
    "codec": "h264",
    "bitrate_kbps": 3000,
    "gop": 30,
    "max_b_frames": 0,
    "preset": "ultrafast",
    "tune": "zerolatency",
    "thread_count": 0,
    "thread_type": "slice"
  },
  "network": {
    "remote_ip": "host.docker.internal",
    "remote_port": 5600,
    "port_step": 2,
    "mtu": 1200,
    "ttl": 64,
    "socket_buffer_bytes": 4194304
  },
  "runtime": {
    "queue_size": 4,
    "camera_timeout_ms": 100,
    "watchdog_interval_ms": 1000,
    "degraded_threshold": 10,
    "reconnect_backoff_ms": [1000, 2000, 5000, 10000],
    "log_interval_ms": 2000,
    "adaptive_drop_enabled": true,
    "adaptive_drop_max_divisor": 4,
    "sync_profile_across_channels": true
  }
}
