      "window_name": "cam0"
    },
    {
      "channel_id": "cam1",
      "listen_port": 5602,
      "window_name": "cam1"
    },
    {
      "channel_id": "cam2",
      "listen_port": 5604,
      "window_name": "cam2"
    }
  ]
